# Development Environment Configuration for dev.isling.me domains
# This configuration uses Cloud SQL for databases (not Docker PostgreSQL)
# Copy this file to .env and update with your actual values

# Cloud SQL Database Configuration
CLOUD_SQL_PROJECT_ID=isling-dev-isling
CLOUD_SQL_REGION=europe-west1
CLOUD_SQL_INSTANCE_NAME=dev01-ew1-postgres-isling
CLOUD_SQL_PRIVATE_IP=192.168.200.0
CLOUD_SQL_CONNECTION_NAME=isling-dev-isling:europe-west1:dev01-ew1-postgres-isling

# Auth Service Configuration (Cloud SQL)
AUTH_SERVICE_HOST=auth.dev.isling.me
AUTH_SERVICE_POSTGRES_USER=supabase_auth_admin
AUTH_SERVICE_POSTGRES_PASSWORD=your_production_auth_password
AUTH_SERVICE_POSTGRES_DB=auth
AUTH_SERVICE_DB_HOST=${CLOUD_SQL_PRIVATE_IP}
AUTH_SERVICE_DB_PORT=5432
AUTH_SERVICE_JWT_SECRET=your_jwt_secret_key_32_characters_long
AUTH_SERVICE_API_EXTERNAL_URL=https://auth.dev.isling.me
AUTH_SERVICE_SITE_URL=https://dev-app.isling.me
AUTH_SERVICE_ADDITIONAL_REDIRECT_URLS=https://dev-app.isling.me
AUTH_SERVICE_DISABLE_SIGNUP=false
AUTH_SERVICE_JWT_EXPIRY=3600

# Auth Service Database URL (Cloud SQL)
AUTH_SERVICE_DATABASE_URL=postgresql://${AUTH_SERVICE_POSTGRES_USER}:${AUTH_SERVICE_POSTGRES_PASSWORD}@${CLOUD_SQL_PRIVATE_IP}:5432/${AUTH_SERVICE_POSTGRES_DB}

# Email Configuration with 1-hour expiration
AUTH_SERVICE_ENABLE_EMAIL_SIGNUP=true
AUTH_SERVICE_ENABLE_EMAIL_AUTOCONFIRM=true
AUTH_SERVICE_SMTP_ADMIN_EMAIL=dev-noreply@isling.me
AUTH_SERVICE_SMTP_HOST=smtp.sendgrid.net
AUTH_SERVICE_SMTP_PORT=465
AUTH_SERVICE_SMTP_USER=apikey
AUTH_SERVICE_SMTP_PASS=your_app_password
AUTH_SERVICE_SMTP_SENDER_NAME="No-Reply"
AUTH_SERVICE_MAILER_URLPATHS_INVITE=/auth/confirm
AUTH_SERVICE_MAILER_URLPATHS_CONFIRMATION=/auth/confirm
AUTH_SERVICE_MAILER_URLPATHS_RECOVERY=/auth/reset-password
AUTH_SERVICE_MAILER_URLPATHS_EMAIL_CHANGE=/auth/confirm

# API Service Configuration (Cloud SQL)
API_SERVICE_HOST=api.dev.isling.me
API_SERVICE_POSTGRES_USER=api_user
API_SERVICE_POSTGRES_PASSWORD=your_production_api_password
API_SERVICE_POSTGRES_DB=api
API_SERVICE_DB_HOST=${CLOUD_SQL_PRIVATE_IP}
API_SERVICE_DB_PORT=5432
API_SERVICE_APP_NAME=Isling API
API_SERVICE_APP_URL=https://api.dev.isling.me

# API Service Database URL (Cloud SQL)
API_SERVICE_DATABASE_URL=postgresql://${API_SERVICE_POSTGRES_USER}:${API_SERVICE_POSTGRES_PASSWORD}@${CLOUD_SQL_PRIVATE_IP}:5432/${API_SERVICE_POSTGRES_DB}

# Redis Configuration (still containerized)
REDIS_URL=redis://api-redis:6379/0

# MQTT Service Configuration
MQTT_SERVICE_HOST=mqtt.dev.isling.me

# Traefik Dashboard Configuration
TRAEFIK_DASHBOARD_HOST=traefik.dev.isling.me

# Phone Authentication (Optional)
AUTH_SERVICE_ENABLE_PHONE_SIGNUP=false
AUTH_SERVICE_ENABLE_PHONE_AUTOCONFIRM=false
AUTH_SERVICE_ENABLE_ANONYMOUS_USERS=false

# GCP Configuration
API_SERVICE_USER_ASSET_BUCKET=dev01-isling-me-asset
API_SERVICE_GOOGLE_APPLICATION_CREDENTIALS=credentials/isling-me-0a7b26fb2468.json

# Integration Services

# Monitoring and Logging
LOG_LEVEL=info
NODE_ENV=production

# Security
VERIFY_TOKEN=FALSE

# Notification Configuration
NOTIFICATION_MQTT_URL=mqtt://api-mqtt01:2883
NOTIFICATION_MERGE_THRESHOLD=28800

# Distributed Locks (Redis)
MUTEX_REDIS1_HOST=api-redis
MUTEX_REDIS1_PORT=6379
MUTEX_REDIS2_HOST=api-redis
MUTEX_REDIS2_PORT=6379
MUTEX_REDIS3_HOST=api-redis
MUTEX_REDIS3_PORT=6379 
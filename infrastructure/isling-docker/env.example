AUTH_SERVICE_SITE_URL=https://dev-app.isling.me
AUTH_SERVICE_ADDITIONAL_REDIRECT_URLS=
AUTH_SERVICE_DISABLE_SIGNUP=FALSE
AUTH_SERVICE_JWT_EXPIRY=3600
AUTH_SERVICE_JWT_SECRET=<secret>
AUTH_SERVICE_ENABLE_EMAIL_SIGNUP=TRUE
AUTH_SERVICE_ENABLE_ANONYMOUS_USERS=FALSE
AUTH_SERVICE_ENABLE_EMAIL_AUTOCONFIRM=TRUE          # BYPASS email confirmation
AUTH_SERVICE_SMTP_ADMIN_EMAIL=dev-noreply@isling.me # No need if BYPASS email confirmation

AUTH_SERVICE_SMTP_PORT=465                          # No need if BYPASS email confirmation
AUTH_SERVICE_SMTP_USER=apikey                       # No need if BYPASS email confirmation
AUTH_SERVICE_SMTP_PASS=<pass>                       # No need if BYPASS email confirmation
AUTH_SERVICE_SMTP_SENDER_NAME="No-Reply"            # No need if BYPASS email confirmation
AUTH_SERVICE_ENABLE_PHONE_SIGNUP=FALSE
AUTH_SERVICE_ENABLE_PHONE_AUTOCONFIRM=TRUE
AUTH_SERVICE_HOST=auth.docker.localhost


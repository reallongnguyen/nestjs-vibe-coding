pnpm run format

# Get staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v 'src/generated/' | tr '\n' ' ')

# Only run lint if there are staged TypeScript files
if [ -n "$STAGED_TS_FILES" ]; then
  echo "Linting staged TypeScript files: $STAGED_TS_FILES"
  npx eslint $STAGED_TS_FILES --fix
  
  # Add the fixed files back to staging
  git add $STAGED_TS_FILES
else
  echo "No TypeScript files to lint"
fi

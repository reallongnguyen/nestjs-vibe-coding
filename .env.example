#######################################
# Core Application Configuration
#######################################

# Application metadata
APP_NAME="API Service"
APP_URL=https://api.isling.me
APP_PORT=8000
NODE_ENV=development

# Logging
LOG_LEVEL=trace

#######################################
# Database & Caching
#######################################

# PostgreSQL connection
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/postgres?schema=public
POSTGRES_USER=<user>
POSTGRES_PASSWORD=<password>
POSTGRES_DB=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

#######################################
# Security & Rate Limiting
#######################################

# JWT Authentication
# VERIFY_TOKEN=true
# JWT_SECRET=<secret>

# Rate limiting configuration
# THROTTLE_TTL=60000      # Time window in milliseconds
# THROTTLE_LIMIT=60       # Maximum requests per window

#######################################
# File Storage & Assets
#######################################

# Google Cloud Storage
USER_ASSET_BUCKET=api-dev01-user-asset
GOOGLE_APPLICATION_CREDENTIALS="<PATH_TO_SERVICE_ACCOUNT_JSON_FILE>"

# Image Proxy Configuration
IMGPROXY_URL=https://img.isling.me
IMGPROXY_KEY=secret
IMGPROXY_SALT=salt

#######################################
# Notification System
#######################################

# MQTT Configuration
NOTIFICATION_MQTT_URL=mqtt://localhost:2883
NOTIFICATION_MERGE_THRESHOLD=28800  # Merge window in seconds

#######################################
# Distributed System
#######################################

# Redis Mutex Configuration (for distributed locks)
MUTEX_REDIS1_HOST=localhost
MUTEX_REDIS1_PORT=6379
MUTEX_REDIS2_HOST=localhost
MUTEX_REDIS2_PORT=6379
MUTEX_REDIS3_HOST=localhost
MUTEX_REDIS3_PORT=6379

#######################################
# Monitoring & Metrics
#######################################

# API Key for metrics access
METRICS_API_KEY=

#######################################
# Feed module
#######################################

# Disable feed cache. Default is false.
FEED_CACHE_DISABLED=false

# Feed cache TTL. Default is 16 seconds.
FEED_CACHE_TTL=16

#######################################
# External Services
#######################################

# Gorse Recommendation Engine
GORSE_URL=http://gorse.docker.localhost
GORSE_API_KEY=gorse

########################################################
# Auth Service
########################################################
AUTH_SERVICE_POSTGRES_USER=<user>
AUTH_SERVICE_POSTGRES_PASSWORD=<password>
AUTH_SERVICE_POSTGRES_DB=auth
AUTH_SERVICE_API_EXTERNAL_URL=http://auth.docker.localhost/
AUTH_SERVICE_SITE_URL=https://isling.me/
AUTH_SERVICE_ADDITIONAL_REDIRECT_URLS=
AUTH_SERVICE_DISABLE_SIGNUP=FALSE
AUTH_SERVICE_JWT_EXPIRY=3600
AUTH_SERVICE_JWT_SECRET=<secret>
AUTH_SERVICE_ENABLE_EMAIL_SIGNUP=TRUE
AUTH_SERVICE_ENABLE_ANONYMOUS_USERS=FALSE
AUTH_SERVICE_ENABLE_EMAIL_AUTOCONFIRM=TRUE
AUTH_SERVICE_SMTP_ADMIN_EMAIL=<email>
AUTH_SERVICE_SMTP_HOST=smtp.sendgrid.net
AUTH_SERVICE_SMTP_PORT=465
AUTH_SERVICE_SMTP_USER=apikey
AUTH_SERVICE_SMTP_PASS=<pass>
AUTH_SERVICE_SMTP_SENDER_NAME="No-reply"
AUTH_SERVICE_MAILER_URLPATHS_INVITE=
AUTH_SERVICE_MAILER_URLPATHS_CONFIRMATION=
AUTH_SERVICE_MAILER_URLPATHS_RECOVERY=
AUTH_SERVICE_MAILER_URLPATHS_EMAIL_CHANGE=
AUTH_SERVICE_ENABLE_PHONE_SIGNUP=FALSE
AUTH_SERVICE_ENABLE_PHONE_AUTOCONFIRM=TRUE
AUTH_SERVICE_HOST=auth.docker.localhost

########################################################
# API Service
########################################################
API_SERVICE_POSTGRES_USER=<user>
API_SERVICE_POSTGRES_PASSWORD=<password>
API_SERVICE_POSTGRES_DB=isling
API_SERVICE_USER_ASSET_BUCKET=dev01-isling-me-asset
API_SERVICE_GOOGLE_APPLICATION_CREDENTIALS_FILENAME=<credential_filename>
API_SERVICE_APP_NAME="API Service"
API_SERVICE_APP_URL="http://api.docker.localhost/"
API_SERVICE_HOST=api.docker.localhost
API_SERVICE_IMGPROXY_URL=http://img.docker.localhost
API_SERVICE_IMGPROXY_KEY=your-secure-key
API_SERVICE_IMGPROXY_SALT=your-secure-salt
API_SERVICE_GORSE_API_KEY=change_me_in_production

########################################################
# Image Proxy
########################################################
IMGPROXY_HOST=img.docker.localhost
IMGPROXY_KEY=your-secure-key
IMGPROXY_SALT=your-secure-salt

# Google Cloud Storage Configuration
IMGPROXY_GCS_KEY_JSON=base64-encoded-service-account-key
IMGPROXY_GCS_ALLOWED_BUCKETS=user-assets,public-assets

########################################################
# Gorse
########################################################
GORSE_MASTER_HOST=gorse.docker.localhost
GORSE_ADMIN_USER=admin
GORSE_ADMIN_PASS=change_me_in_production
GORSE_API_KEY=change_me_in_production
GORSE_POSTGRES_USER=gorse
GORSE_POSTGRES_PASSWORD=change_me_in_production
GORSE_POSTGRES_DB=gorse

# Gorse Performance Tuning
GORSE_CACHE_SIZE=100000
GORSE_NUM_WORKERS=2
GORSE_WORKER_THREADS=4
GORSE_UPDATE_INTERVAL=300
GORSE_RECOMMEND_CACHE_TTL=3600
